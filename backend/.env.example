APP_NAME=flow-office
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# フロントエンド(別アプリ)のURL。Entra ID SSOコールバック後のリダイレクト先として使う。
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Microsoft Entra ID SSO (docs/06-usecases-auth.md UC-001) ---
# Azure Portal でアプリ登録した際の値を設定する。未設定でもアプリ自体は起動できる。
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"

# ローカル開発でEntra IDの代わりにmock-oidc/のモックサーバーでログインしたい場合はtrueにする。
# devcontainer/docker-compose環境ではdevcontainer.jsonのpostCreateCommandで自動設定される。
# 本番・検証環境では設定しないこと。
MICROSOFT_MOCK_ENABLED=false
MICROSOFT_MOCK_PUBLIC_BASE_URL=http://localhost:9000
MICROSOFT_MOCK_INTERNAL_BASE_URL=http://localhost:9000

# --- Microsoft Graph (docs/06-usecases-auth.md UC-002 ユーザー同期) ---
MS_GRAPH_TENANT_ID="${MICROSOFT_TENANT_ID}"
MS_GRAPH_CLIENT_ID="${MICROSOFT_CLIENT_ID}"
MS_GRAPH_CLIENT_SECRET="${MICROSOFT_CLIENT_SECRET}"

# --- Teams通知 (docs/13-usecases-notification.md UC-N001) ---
# Webhook URL未設定時はログ出力のみに留める(開発環境向けフォールバック)。
TEAMS_WEBHOOK_URL=
