APP_NAME=flow-office
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_API_PREFIX=api

# フロントエンド(別アプリ)のURL。Entra ID SSOコールバック後のリダイレクト先として使う。
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Microsoft Entra ID SSO (docs/06-usecases-auth.md UC-000/UC-001) ---
# 本番・検証環境ではここを設定しない。SSOログイン・MS365ユーザー同期・メール通知が共有する
# Entra IDの資格情報(テナントID・クライアントID・クライアントシークレット・リダイレクトURI)は
# `system_settings`(DB)で管理し、初回オンボーディング画面(未認証で開ける
# `POST /api/onboarding`)から登録する。
#
# 以下はローカル開発・devcontainer・E2Eテストでmock-oidc/を使う場合の値としてのみ使われる。
# `SystemSetting::current()`が初回作成時にここから読み込み、システムをオンボーディング済みの
# 状態でシードする(devcontainer.jsonのpostCreateCommandで自動設定される)。
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI="${APP_URL}/api/auth/microsoft/callback"

# ローカル開発でEntra IDの代わりにmock-oidc/のモックサーバーでログインしたい場合はtrueにする。
# devcontainer/docker-compose環境ではdevcontainer.jsonのpostCreateCommandで自動設定される。
# 本番・検証環境では設定しないこと。
MICROSOFT_MOCK_ENABLED=false
MICROSOFT_MOCK_PUBLIC_BASE_URL=http://localhost:9000
MICROSOFT_MOCK_INTERNAL_BASE_URL=http://localhost:9000

# --- OpenAPI / Swagger UI ---
# ローカル開発ではリクエストの都度ドキュメントを再生成する。本番ではfalseのままにする。
L5_SWAGGER_GENERATE_ALWAYS=true
