# mcp/ 本番用 .env のサンプル。CIはこのファイルを一切使わない。
#
# 初回セットアップ時にサーバー上でこの内容を元に手動で作成し、
# /home/xsys/xsys.co.jp/flow-office/shared/mcp/.env として設置する
# (以後のデプロイはこのファイルをリリースディレクトリへシンボリックリンクするだけで、
# 再生成・上書きは一切しない。docs/28-github-actions-deploy.md参照)。
#
# APP_KEY・DB_PASSWORD等の値は、このファイルを直接編集して埋めること
# (GitHub Secretsには含めない)。backend/とは別のデータベースを使うこと。

APP_NAME="flow-office-mcp"
APP_ENV=production
APP_KEY=                              # php artisan key:generate --show で生成した値を固定で入れる
APP_DEBUG=false
APP_URL=https://xsys.co.jp/flow-office/mcp

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql8015.xserver.jp
DB_PORT=3306
DB_DATABASE=xsys_db_mcp
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

VITE_APP_NAME="flow-office-mcp"

# backend/ のAPIベースURL。mcp/はこのAPIのクライアントであり、DBへは直接アクセスしない。
MCP_BACKEND_API_BASE_URL=https://xsys.co.jp/flow-office/api/

# OAuth2アクセストークン(JWT)の署名鍵。初回デプロイ時にactivate-release.shがサーバー上で
# `php artisan mcp:oauth-keys` を実行して生成し、shared/mcp/storageに永続化する
# (devの鍵を使い回さないこと。docs/27-release-runbook.md参照)。
MCP_OAUTH_PRIVATE_KEY_PATH=storage/oauth-private.key
MCP_OAUTH_PUBLIC_KEY_PATH=storage/oauth-public.key
MCP_OAUTH_ACCESS_TOKEN_TTL_MINUTES=60
MCP_OAUTH_REFRESH_TOKEN_TTL_DAYS=30
MCP_OAUTH_AUTH_CODE_TTL_MINUTES=10
