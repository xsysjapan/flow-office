# backend/ 本番用 .env のサンプル。CIはこのファイルを一切使わない。
#
# 初回セットアップ時にサーバー上でこの内容を元に手動で作成し、
# /home/xsys/xsys.co.jp/flow-office/shared/backend/.env として設置する
# (以後のデプロイはこのファイルをリリースディレクトリへシンボリックリンクするだけで、
# 再生成・上書きは一切しない。docs/28-github-actions-deploy.md参照)。
#
# APP_KEY・DB_PASSWORD等の値は、このファイルを直接編集して埋めること
# (GitHub Secretsには含めない)。

APP_NAME=flow-office
APP_ENV=production
APP_KEY=                              # php artisan key:generate --show で生成した値を固定で入れる
APP_DEBUG=false
APP_URL=https://xsys.co.jp/flow-office/api

# マウントパス自体が'api'セグメントを兼ねるため空にする(docs/27-release-runbook.md)
APP_API_PREFIX=

FRONTEND_URL=https://xsys.co.jp/flow-office

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql8015.xserver.jp
DB_PORT=3306
DB_DATABASE=xsys_db
DB_USERNAME=xsys_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="flow-office"

# Entra ID資格情報はsystem_settings(DB)で管理するため、本番では設定しない
# (docs/06-usecases-auth.md, backend/.env.example参照)。
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_MOCK_ENABLED=false

L5_SWAGGER_GENERATE_ALWAYS=false
